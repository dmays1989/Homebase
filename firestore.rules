// firestore.rules
// Paste these in Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Home members can read/write their home and all subcollections
    match /homes/{homeId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.members;

      allow create: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/homes/$(homeId)).data.members;

        match /{nested=**} {
          allow read, write: if request.auth != null &&
            request.auth.uid in get(/databases/$(database)/documents/homes/$(homeId)).data.members;
        }
      }
    }
  }
}
